# Xiaotao WebDAV 同步工具配置
# 复制此文件为 .env 并填写你的配置

# =============================================================================
# WebDAV 配置（以坚果云为例）
# =============================================================================
WEBDAV_URL=https://dav.jianguoyun.com/dav/
WEBDAV_USERNAME=your_username
WEBDAV_PASSWORD=your_app_password

# 可选：自定义目录路径
# WEBDAV_FLASHNOTE_DIR=/flashnotes/
# WEBDAV_FINALNOTE_DIR=/All/Daily/

# =============================================================================
# AI 服务配置（阿里云百炼 Coding Plan）
# =============================================================================
AI_API_KEY=your_api_key

# 可选：自定义模型和端点
# AI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# AI_MODEL=kimi-k2.5

# =============================================================================
# 本地数据目录
# =============================================================================
# 优先级：环境变量 > 命令行参数 --local-dir > 默认值(./xiaotao_data)
LOCAL_DATA_DIR=~/xiaotao_data
